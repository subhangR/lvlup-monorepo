---
const steps = [
  {
    step: 1,
    title: 'Set Up Your School',
    description: 'Create your school profile, configure grading preferences, and customise your branding. Your school\'s data stays fully isolated from day one.',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>`,
  },
  {
    step: 2,
    title: 'Add Your People',
    description: 'Import teachers, students, and parents with a single CSV upload — or invite them individually. Everyone gets their own dashboard from the start.',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  },
  {
    step: 3,
    title: 'Teach and Assign',
    description: 'Teachers build learning spaces with 15 question types, assign them to classes, and let the AI tutor support students between lessons — 24/7.',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
  },
  {
    step: 4,
    title: 'Grade and Grow',
    description: 'Scan handwritten exams with any phone. AutoGrade returns fully graded, feedback-rich reports in 8 minutes. At-risk students are flagged automatically.',
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>`,
  },
];
---

<section id="how-it-works" class="bg-muted/30 py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center scroll-reveal">
      <div class="mb-4 inline-flex rounded-full bg-success/10 px-4 py-1 text-sm font-medium text-success">
        Simple Setup
      </div>
      <h2 class="section-heading">How It Works</h2>
      <p class="section-subheading">
        From sign-up to your first graded exam — in under an hour.
        Here's what the first day looks like.
      </p>
    </div>

    <div class="mt-16">
      <div class="relative">
        <!-- Connecting line (desktop) -->
        <div class="absolute left-1/2 top-0 hidden h-full w-0.5 -translate-x-1/2 bg-gradient-to-b from-primary/20 via-primary/40 to-primary/20 lg:block"></div>

        <div class="space-y-12 lg:space-y-0">
          {steps.map((step, index) => (
            <div class={`scroll-reveal relative lg:flex lg:items-center lg:gap-12 ${index > 0 ? 'lg:mt-16' : ''}`} style={`transition-delay: ${index * 150}ms`}>
              {/* Left side (odd) or right side (even) content */}
              <div class={`lg:w-1/2 ${index % 2 === 0 ? 'lg:pr-16 lg:text-right' : 'lg:order-2 lg:pl-16'}`}>
                <div class={`rounded-xl border border-border bg-card p-6 shadow-sm ${index % 2 === 0 ? 'lg:ml-auto' : ''} max-w-lg`}>
                  <div class={`mb-3 flex items-center gap-3 ${index % 2 === 0 ? 'lg:flex-row-reverse' : ''}`}>
                    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary" set:html={step.icon} />
                    <div>
                      <span class="text-xs font-semibold uppercase tracking-wider text-primary">Step {step.step}</span>
                      <h3 class="text-lg font-bold">{step.title}</h3>
                    </div>
                  </div>
                  <p class={`text-sm leading-relaxed text-muted-foreground ${index % 2 === 0 ? 'lg:text-right' : ''}`}>
                    {step.description}
                  </p>
                </div>
              </div>

              {/* Center circle */}
              <div class="absolute left-1/2 hidden h-10 w-10 -translate-x-1/2 items-center justify-center rounded-full border-4 border-background bg-primary text-sm font-bold text-primary-foreground shadow-md lg:flex">
                {step.step}
              </div>

              {/* Spacer for other side */}
              <div class={`hidden lg:block lg:w-1/2 ${index % 2 === 0 ? 'lg:order-2' : ''}`}></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 text-center scroll-reveal">
      <a
        href="/demo"
        class="btn-primary px-8 py-4 text-base shadow-lg shadow-primary/25"
      >
        Book a Demo
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

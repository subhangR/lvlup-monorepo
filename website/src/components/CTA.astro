<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-reveal relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary via-primary to-info p-8 text-center sm:p-12 lg:p-16">
      <!-- Background decorations -->
      <div class="absolute inset-0 -z-0">
        <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
      </div>

      <div class="relative z-10">
        <h2 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
          See What Auto-LevelUp Can Do for Your School
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
          30 minutes. A live walkthrough built around your school's needs.
          See AI grading, adaptive learning, and real-time analytics in action.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">

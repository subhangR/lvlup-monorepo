---
const testimonials = [
  {
    quote: 'We used to spend the first two weeks after exams just on grading. Now our teachers get results back to students the same day. The at-risk alerts alone have changed how we intervene — we catch problems in weeks, not months.',
    name: 'Dr. Meera Sharma',
    role: 'Principal, Delhi Public School',
    initials: 'MS',
  },
  {
    quote: 'I grade 120 answer sheets in under 15 minutes now. The feedback each student gets is more detailed than what I could write by hand for 10. And I still override anything I disagree with — the AI respects my judgment.',
    name: 'Rajesh Iyer',
    role: 'Physics Teacher, Kendriya Vidyalaya',
    initials: 'RI',
  },
  {
    quote: 'My daughter\'s school started using Auto-LevelUp last term. For the first time, I know exactly which topics she\'s struggling with — not at the end of the year, but the same week. That changed everything for us.',
    name: 'Anita Deshmukh',
    role: 'Parent, Class 9 student',
    initials: 'AD',
  },
  {
    quote: 'As a principal, what sold me was the cost visibility. I know exactly what the AI costs us per exam, per month. No surprise invoices. And the staff permission system means I control who does what.',
    name: 'Suresh Menon',
    role: 'Director, Orchid International School',
    initials: 'SM',
  },
  {
    quote: 'The students actually want to study now. They check their XP, compare streaks with friends, and compete on the leaderboard. I\'ve never had a class this engaged in daily practice before Auto-LevelUp.',
    name: 'Kavita Nair',
    role: 'Maths Teacher, Ryan International',
    initials: 'KN',
  },
  {
    quote: 'I used to be scared to ask questions in class. Now I just ask the AI tutor — it doesn\'t judge me, and it helps me figure things out on my own. My grades went up two levels this term.',
    name: 'Arjun Reddy',
    role: 'Student, Class 10',
    initials: 'AR',
  },
];
---

<section id="testimonials" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center scroll-reveal">
      <div class="mb-4 inline-flex rounded-full bg-warning/10 px-4 py-1 text-sm font-medium text-warning">
        Loved by Educators
      </div>
      <h2 class="section-heading">What Our Community Says</h2>
      <p class="section-subheading">
        Hear from the schools, teachers, students, and parents who use Auto-LevelUp every day.
      </p>
    </div>

    <!-- Testimonial carousel -->
    <div
      class="relative mt-16"
      role="region"
      aria-label="Customer testimonials"
      aria-roledescription="carousel"
    >
      <div
        id="testimonial-track"
        class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scroll-smooth"
        style="scrollbar-width: none; -ms-overflow-style: none;"
        aria-live="polite"
      >
        {testimonials.map((t, i) => (
          <div
            class="min-w-[320px] max-w-[400px] flex-shrink-0 snap-center scroll-reveal rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:shadow-md"
            style={`transition-delay: ${i * 100}ms`}
            role="group"
            aria-label={`Testimonial from ${t.name}`}
          >
            <!-- Stars -->
            <div class="mb-4 flex gap-0.5" aria-label="5 out of 5 stars">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="mb-6 text-sm leading-relaxed text-muted-foreground">
              "{t.quote}"
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-primary to-info text-sm font-bold text-white">
                {t.initials}
              </div>
              <div>
                <div class="text-sm font-semibold">{t.name}</div>
                <div class="text-xs text-muted-foreground">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Nav buttons + dot indicators -->
      <div class="mt-6 flex flex-col items-center gap-4">
        <!-- Dots -->
        <div id="testimonial-dots" class="flex items-center gap-2" role="tablist" aria-label="Testimonial navigation">
          {testimonials.map((_, i) => (
            <button
              class="testimonial-dot h-2.5 w-2.5 rounded-full bg-border transition-all hover:bg-primary/50"
              data-index={i}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`Go to testimonial ${i + 1}`}
            ></button>
          ))}
        </div>

        <!-- Prev/Next buttons -->
        <div class="flex items-center gap-3">
          <button
            id="testimonial-prev"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm transition-colors hover:bg-accent"
            aria-label="Previous testimonial"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            id="testimonial-next"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-border bg-card shadow-sm transition-colors hover:bg-accent"
            aria-label="Next testimonial"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #testimonial-track::-webkit-scrollbar {
    display: none;
  }
  .testimonial-dot[aria-selected="true"] {
    background-color: hsl(var(--primary));
    width: 1.25rem;
    border-radius: 9999px;
  }
</style>

<script>
  function initTestimonials() {
    const track = document.getElementById('testimonial-track')!;
    const prev = document.getElementById('testimonial-prev')!;
    const next = document.getElementById('testimonial-next')!;
    const dots = document.querySelectorAll('.testimonial-dot');
    if (!track || !prev || !next) return;

    const scrollAmount = 340;
    let isPaused = false;

    function updateDots() {
      const scrollLeft = track.scrollLeft;
      const cardWidth = 340;
      const activeIndex = Math.round(scrollLeft / cardWidth);
      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === activeIndex ? 'true' : 'false');
      });
    }

    function scrollNext() {
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= maxScroll - 10) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      }
    }

    function startAutoPlay() {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      setInterval(() => {
        if (!isPaused) scrollNext();
      }, 5000);
    }

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    next.addEventListener('click', () => {
      scrollNext();
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = Number(dot.getAttribute('data-index'));
        track.scrollTo({ left: index * scrollAmount, behavior: 'smooth' });
      });
    });

    track.addEventListener('scroll', updateDots);

    // Pause on hover / focus
    const carousel = track.closest('[role="region"]');
    if (carousel) {
      carousel.addEventListener('mouseenter', () => { isPaused = true; });
      carousel.addEventListener('mouseleave', () => { isPaused = false; });
      carousel.addEventListener('focusin', () => { isPaused = true; });
      carousel.addEventListener('focusout', () => { isPaused = false; });
    }

    startAutoPlay();
    updateDots();
  }

  initTestimonials();
  document.addEventListener('astro:after-swap', initTestimonials);
</script>
